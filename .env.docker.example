PANEL_BASE_URL=https://host
PANEL_API_TOKEN=Token
PUBLIC_BASE_URL=http://localhost:3000
PORT=3000

# Optional hidden path prefix for all non-health routes.
# Example: SECRET_PATH=my-secret-path
SECRET_PATH=

# Optional but recommended.
ACCESS_KEY=

# Optional: path to the txt file that contains the latest ECH value.
# The app reads this file on every user/subscription request.
ECH_FILE_PATH=./ech-updater-data/last_ech.txt


# Optional: path to the writable txt file that contains extra hosts.
# One host per line. For every VLESS config, the app keeps the default config
# and creates extra configs with these hosts.
HOSTS_FILE_PATH=./data/hosts.txt

# Optional: custom route for reading/writing the hosts file.
# Default: /api/hosts
# Example: HOSTS_API_PATH=private-hosts-api
HOSTS_API_PATH=/api/hosts
