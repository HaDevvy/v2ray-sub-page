PANEL_BASE_URL=https://host
PANEL_API_TOKEN=Token
PUBLIC_BASE_URL=http://localhost:3000
PORT=3000

# Optional: put all app routes behind a hidden prefix.
# Example: SECRET_PATH=my-secret-path
# Result: http://localhost:3000/my-secret-path/u/EMAIL
SECRET_PATH=

# Optional but recommended. If set, page/sub/API require ?key=... or x-access-key header.
ACCESS_KEY=

# Optional: path to the txt file that contains the latest ECH value.
# The app reads this file on every user/subscription request.
ECH_FILE_PATH=./ech-updater-data/last_ech.txt


# Optional: directory for per-source-host txt files.
# Example file: ./data/hosts/market.hqmq.com.txt
# Only configs whose authority host is market.hqmq.com use that file.
HOSTS_DIR_PATH=./data/hosts

# Optional: custom route for reading/writing per-host files.
# Default: /api/hosts
# Example: HOSTS_API_PATH=private-hosts-api
HOSTS_API_PATH=/api/hosts
