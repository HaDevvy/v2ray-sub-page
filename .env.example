# آدرس پنل بدون اسلش انتهایی
PANEL_BASE_URL=https://host

# فقط مقدار توکن را بگذارید. اگر Bearer را هم بگذارید، برنامه خودش مدیریت می‌کند.
PANEL_API_TOKEN=Token

# آدرس عمومی پروژه برای ساخت لینک subscription و QR
# مثال: https://sub.example.com
PUBLIC_BASE_URL=http://localhost:3000

# پورت اجرا
PORT=3000

# اختیاری: برای جلوگیری از abuse، یک کلید ساده برای دیدن صفحه بگذارید.
# اگر خالی باشد غیرفعال است. نمونه استفاده: /u/email?key=secret
ACCESS_KEY=
